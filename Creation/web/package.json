{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "npm run lint:eslint && npm run lint:stylelint",
    "lint:eslint": "eslint \"src/**/*.{js,vue}\" --max-warnings=0",
    "lint:stylelint": "stylelint \"src/**/*.{css,vue}\" --max-warnings=0",
    "test": "vitest run --coverage",
    "test:visual": "playwright test"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.3",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "lighthouse": "^13.1.0",
    "postcss": "^8.5.9",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.8.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.3"
  }
